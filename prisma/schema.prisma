generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Note {
  id        String   @id @default(cuid())
  title     String
  content   String
  language  String   @default("plaintext")
  type      NoteType @default(code)
  images    Json     @default("[]")
  shareId   String?  @unique
  isPublic  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shareId])
  @@index([userId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  notes     Note[]
}

enum NoteType {
  code
  text
  mixed
}
